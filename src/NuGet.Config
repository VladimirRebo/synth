<?xml version="1.0" encoding="utf-8"?>
<!--
  Solution-scoped NuGet config so restores are reproducible from the public feed
  alone, without depending on any VPN-gated private source.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
